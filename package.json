{
  "name": "telegram-enchanted",
  "version": "1.0.0",
  "description": "Telegram Enchanted - Mass Media Downloader",
  "author": "Camacho",
  "main": "src/main/main.js",
  "type": "module",
  "scripts": {
    "start": "vite",
    "build": "vite build && electron-builder",
    "electron": "cross-env NODE_ENV=development electron .",
    "dev": "node scripts/dev.mjs"
  },
  "build": {
    "appId": "com.telegram-enchanted.app",
    "productName": "Telegram Enchanted",
    "files": [
      "dist/**/*",
      "src/**/*",
      "build/icon.png",
      "build/icon.svg"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "linux": {
      "icon": "build/icon.png",
      "target": ["AppImage", "snap"]
    },
    "protocols": [
      {
        "name": "Telegram",
        "schemes": ["tg"]
      }
    ],
    "win": {
      "icon": "build/icon.png",
      "target": "nsis"
    },
    "mac": {
      "icon": "build/icon.png"
    }
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "env-paths": "^4.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "telegram": "^2.26.22"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "wait-on": "^9.0.4"
  }
}
